:root {
  --verde: #2f855a;
  --verde-hover: #276749;
  --bg: #f7f7f7;
}

body {
  background: var(--bg);
  font-family: system-ui, sans-serif;
  line-height: 1.6;
}

.contenedor {
  max-width: 900px;
  margin: 0 auto;
  padding: 24px;
}

h1 {
  text-align: center;
  margin-bottom: 8px;
}

.subtitulo {
  color: #4a5568;
  margin: 4px 0 20px;
  text-align: center;
}

h2 {
  margin-top: 32px;
  margin-bottom: 12px;
  color: #333;
}

.grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  margin-bottom: 20px;
}

@media (min-width: 720px) {
  .grid {
    grid-template-columns: 1fr 1fr;
  }
}

.boton {
  display: block;
  text-align: center;
  padding: 12px 16px;
  background: var(--verde);
  color: #fff;
  text-decoration: none;
  border-radius: 12px;
  font-weight: 700;
  transition: transform .08s ease, background .2s ease;
}

.boton:hover {
  background: var(--verde-hover);
  transform: translateY(-1px);
}
/* Forzar que el ítem ocupe toda la fila del grid */
.boton--full { 
  grid-column: 1 / -1;
}

